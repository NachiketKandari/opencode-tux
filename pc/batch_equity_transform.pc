/*
 * batch_equity_transform.pc - Tuxedo Batch Equity Transform Service
 *
 * Processes validated equity data: computes derived metrics, updates
 * portfolio valuations, calculates user P&L, and chains to reporting.
 *
 * Service: BATCH_EQUITY_TRANSFORM
 * Complexity: MEDIUM (~550 lines)
 *
 * Real-world analogue: ICICI Securities' end-of-day MTM (mark-to-market)
 * batch that updates every client portfolio with latest prices, computes
 * unrealized P&L, triggers margin calls, and generates risk reports.
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>
#include <atmi.h>
#include <userlog.h>

EXEC SQL INCLUDE SQLCA;

EXEC SQL BEGIN DECLARE SECTION;
    VARCHAR uid[30];
    VARCHAR pwd[30];

    /* Cursor host variables for validated staging rows */
    int     c_row_id;
    char    c_ticker[32];
    int     c_batch_id;
    char    c_date[16];
    double  c_open;
    double  c_high;
    double  c_low;
    double  c_close;
    long    c_volume;

    /* SELECT INTO host variables */
    double  h_prev_close;
    double  h_sma_50;
    double  h_sma_200;
    double  h_volatility_30d;
    double  h_daily_return;

    /* Portfolio cursor variables */
    int     c_portfolio_id;
    int     c_user_id;
    char    c_pf_ticker[32];
    int     c_quantity;
    double  c_avg_buy_price;
    double  c_invested_amount;
    char    c_portfolio_type[16];
    char    c_risk_profile[16];
    double  c_current_price;

    /* Upsert variables */
    double  h_upsert_price;
    double  h_upsert_sma50;
    double  h_upsert_sma200;
    double  h_upsert_volatility;
    double  h_upsert_daily_return;

    /* Portfolio valuation variables */
    double  h_current_market_value;
    double  h_unrealized_pnl;
    double  h_unrealized_pnl_pct;
    double  h_total_portfolio_value;
    int     h_portfolio_update_count;

    /* Margin variables */
    double  h_margin_required;
    double  h_margin_available;
    double  h_margin_shortfall;
    char    h_margin_status[16];

    /* Risk classification */
    char    h_ticker_sector[64];
    double  h_pe_ratio;
    double  h_beta;
    double  h_debt_equity;
    double  h_market_cap;

    /* Counters */
    int     h_total_processed;
    int     h_metrics_computed;
    int     h_portfolio_updated;
    int     h_margin_calls;
    int     h_skipped_low_words;  /* equity equivalent: low volume filter */
    int     h_transform_errors;
    int     h_commit_count;

    /* Status */
    char    h_status_msg[1024];
EXEC SQL END DECLARE SECTION;

static void sql_error(char *msg)
{
    userlog("[FATAL] %s: sqlcode=%ld", msg, sqlca.sqlcode);
    EXEC SQL ROLLBACK;
}

/* ─── tpsvrinit ────────────────────────────────────────────────────── */

int tpsvrinit(int argc, char *argv[])
{
    (void)argc; (void)argv;
    userlog("tpsvrinit: Initializing BATCH_EQUITY_TRANSFORM");

    strcpy((char *)uid.arr, "batch_user");
    uid.len = strlen((char *)uid.arr);
    strcpy((char *)pwd.arr, "batch_pass");
    pwd.len = strlen((char *)pwd.arr);

    EXEC SQL WHENEVER SQLERROR DO sql_error("tpsvrinit CONNECT");
    EXEC SQL CONNECT :uid IDENTIFIED BY :pwd;

    if (sqlca.sqlcode != 0) {
        userlog("tpsvrinit: CONNECT failed. sqlcode=%ld", sqlca.sqlcode);
        return -1;
    }

    userlog("tpsvrinit: BATCH_EQUITY_TRANSFORM ready");
    return 0;
}

/* ─── tpsvrdone ────────────────────────────────────────────────────── */

void tpsvrdone(void)
{
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    EXEC SQL COMMIT WORK RELEASE;
    userlog("tpsvrdone: Processed=%d, Portfolios=%d, MarginCalls=%d",
            h_total_processed, h_portfolio_updated, h_margin_calls);
}

/* ─── Helper: Classify risk tier ─────────────────────────────────────
 * In ICICI Securities, risk tiers determine margin requirements,
 * position limits, and surveillance intensity. */

static const char *classify_risk_tier(double beta, double debt_equity, double pe)
{
    /* AGGRESSIVE: high beta, high leverage, high valuation */
    if (beta > 1.5 && debt_equity > 2.0) return "HIGH_RISK";
    if (beta > 1.2 || debt_equity > 1.5 || pe > 50.0) return "ELEVATED_RISK";
    if (beta > 0.8 && debt_equity < 1.0 && pe < 30.0) return "MODERATE_RISK";
    if (beta > 0.0 && beta <= 0.8 && debt_equity < 0.5) return "LOW_RISK";
    return "STANDARD_RISK";
}

/* ─── Helper: Determine margin requirement ───────────────────────────
 * Based on risk tier and portfolio type (delivery, margin, intraday). */

static double calc_margin_pct(const char *risk_tier, const char *portfolio_type)
{
    if (strcmp(portfolio_type, "INTRADAY") == 0) {
        if (strcmp(risk_tier, "HIGH_RISK") == 0) return 40.0;
        if (strcmp(risk_tier, "ELEVATED_RISK") == 0) return 30.0;
        return 20.0;
    } else if (strcmp(portfolio_type, "MARGIN") == 0) {
        if (strcmp(risk_tier, "HIGH_RISK") == 0) return 50.0;
        if (strcmp(risk_tier, "ELEVATED_RISK") == 0) return 35.0;
        return 25.0;
    } else {
        /* DELIVERY — full payment, no margin */
        return 0.0;
    }
}

/* ─── BATCH_EQUITY_TRANSFORM Service ───────────────────────────────── */

void BATCH_EQUITY_TRANSFORM(TPSVCINFO *rqst)
{
    char *input_data = rqst->data;
    int  target_batch_id = 0;

    userlog("BATCH_EQUITY_TRANSFORM: Starting transformation");

    if (input_data && strlen(input_data) > 0 && strncmp(input_data, "BATCH=", 6) == 0) {
        target_batch_id = atoi(input_data + 6);
    }

    EXEC SQL WHENEVER SQLERROR GOTO transform_error;

    h_total_processed = 0;
    h_metrics_computed = 0;
    h_portfolio_updated = 0;
    h_margin_calls = 0;
    h_skipped_low_words = 0;
    h_transform_errors = 0;
    h_commit_count = 0;

    /* ── Phase 1: Compute derived metrics for each validated stock ──
     * This is the core transformation: raw prices → analytics.
     * In ICICI production, this phase runs 200+ derived computations
     * including technical indicators, risk metrics, and ratios.
     */

    EXEC SQL DECLARE transform_cursor CURSOR FOR
        SELECT row_id, ticker, batch_id, date, open, high, low, close, volume
        FROM equity_staging
        WHERE ingest_status = 'VALIDATED'
        ORDER BY ticker, date;

    EXEC SQL OPEN transform_cursor;

    if (sqlca.sqlcode != 0) {
        userlog("BATCH_EQUITY_TRANSFORM: Cursor open failed");
        tpreturn(TPFAIL, sqlca.sqlcode, "FAIL|cursor_open", 0, 0);
        return;
    }

    while (1) {
        EXEC SQL FETCH transform_cursor INTO
            :c_row_id, :c_ticker, :c_batch_id, :c_date,
            :c_open, :c_high, :c_low, :c_close, :c_volume;

        if (sqlca.sqlcode == 100) break;
        if (sqlca.sqlcode != 0) goto transform_error;

        h_total_processed++;

        /* Skip stocks with very low volume (illiquid, unreliable data) */
        if (c_volume < 10) {
            h_skipped_low_words++;
            EXEC SQL UPDATE equity_staging
                SET ingest_status = 'TRANSFORMED',
                    validation_msg = 'SKIPPED|low_volume'
                WHERE row_id = :c_row_id;
            continue;
        }

        /* ── Compute derived metrics ── */

        /* Daily return = (close - open) / open * 100 */
        h_daily_return = ((c_close - c_open) / c_open) * 100.0;

        /* Fetch previous close for volatility context */
        EXEC SQL SELECT close INTO :h_prev_close
            FROM eod_prices
            WHERE ticker = :c_ticker AND date < :c_date
            ORDER BY date DESC LIMIT 1;

        /* Compute SMA-50 if we have enough history */
        EXEC SQL SELECT AVG(close) INTO :h_sma_50
            FROM (
                SELECT close FROM eod_prices
                WHERE ticker = :c_ticker AND date <= :c_date
                ORDER BY date DESC LIMIT 50
            );

        /* Compute SMA-200 */
        EXEC SQL SELECT AVG(close) INTO :h_sma_200
            FROM (
                SELECT close FROM eod_prices
                WHERE ticker = :c_ticker AND date <= :c_date
                ORDER BY date DESC LIMIT 200
            );

        /* 30-day volatility (standard deviation of daily returns) */
        EXEC SQL SELECT
            AVG((close - prev_close) / prev_close * 100.0 *
                (close - prev_close) / prev_close * 100.0)
            INTO :h_volatility_30d
            FROM (
                SELECT close,
                    LAG(close, 1) OVER (ORDER BY date) as prev_close
                FROM eod_prices
                WHERE ticker = :c_ticker AND date <= :c_date
                ORDER BY date DESC LIMIT 30
            );

        /* ── Upsert derived metrics ──
         * In production ICICI code, there are ~50+ derived columns computed
         * here including RSI, MACD, Bollinger Bands, ATR, OBV, etc.
         */
        EXEC SQL INSERT OR REPLACE INTO equity_derived_metrics
            (ticker, date, sma_50, sma_200, daily_return, volatility_30d)
            VALUES (:c_ticker, :c_date, :h_sma_50, :h_sma_200,
                    :h_daily_return, :h_volatility_30d);

        h_metrics_computed++;

        /* Mark staging row as transformed */
        EXEC SQL UPDATE equity_staging
            SET ingest_status = 'TRANSFORMED'
            WHERE row_id = :c_row_id;

        /* Commit every 200 rows */
        h_commit_count++;
        if (h_commit_count >= 200) {
            EXEC SQL COMMIT;
            h_commit_count = 0;
        }
    }

    EXEC SQL CLOSE transform_cursor;
    EXEC SQL COMMIT;

    /* ── Phase 2: Portfolio mark-to-market ──
     * Update every user portfolio holding with latest close price.
     * Compute unrealized P&L for each holding.
     * This is the most critical batch at ICICI Securities — it runs
     * every evening after market close and determines next-day margin.
     */

    userlog("BATCH_EQUITY_TRANSFORM: Phase 2 — Portfolio MTM");

    EXEC SQL DECLARE portfolio_cursor CURSOR FOR
        SELECT pf.portfolio_id, pf.user_id, pf.ticker, pf.quantity,
               pf.avg_buy_price, pf.invested_amount, pf.portfolio_type,
               u.risk_profile, sf.current_price
        FROM user_portfolios pf
        JOIN users u ON pf.user_id = u.user_id
        LEFT JOIN stock_fundamentals sf ON pf.ticker = sf.ticker
        WHERE u.account_status = 'ACTIVE'
        ORDER BY pf.user_id, pf.ticker;

    EXEC SQL OPEN portfolio_cursor;

    if (sqlca.sqlcode != 0) {
        userlog("BATCH_EQUITY_TRANSFORM: Portfolio cursor open failed");
        goto phase3_report;
    }

    while (1) {
        EXEC SQL FETCH portfolio_cursor INTO
            :c_portfolio_id, :c_user_id, :c_pf_ticker, :c_quantity,
            :c_avg_buy_price, :c_invested_amount, :c_portfolio_type,
            :c_risk_profile, :c_current_price;

        if (sqlca.sqlcode == 100) break;
        if (sqlca.sqlcode != 0) goto transform_error;

        /* ── Fetch stock fundamentals for risk classification ── */
        EXEC SQL SELECT sector, pe_ratio, beta, debt_to_equity, market_cap_crore
            INTO :h_ticker_sector, :h_pe_ratio, :h_beta, :h_debt_equity, :h_market_cap
            FROM stock_fundamentals
            WHERE ticker = :c_pf_ticker;

        /* Determine risk tier and margin */
        {
            const char *risk_tier = classify_risk_tier(h_beta, h_debt_equity, h_pe_ratio);
            double margin_pct = calc_margin_pct(risk_tier, c_portfolio_type);

            /* MTM valuation */
            if (c_current_price > 0) {
                h_current_market_value = c_quantity * c_current_price;
                h_unrealized_pnl = h_current_market_value - c_invested_amount;
                h_unrealized_pnl_pct = (h_unrealized_pnl / c_invested_amount) * 100.0;
            } else {
                h_current_market_value = c_invested_amount;
                h_unrealized_pnl = 0.0;
                h_unrealized_pnl_pct = 0.0;
            }

            h_portfolio_updated++;

            /* Margin shortfall check for MARGIN and INTRADAY positions */
            if (margin_pct > 0.0) {
                h_margin_required = h_current_market_value * (margin_pct / 100.0);
                h_margin_available = h_current_market_value - (c_invested_amount * 0.5);
                h_margin_shortfall = h_margin_required - h_margin_available;

                if (h_margin_shortfall > 0) {
                    strcpy(h_margin_status, "MARGIN_CALL");
                    h_margin_calls++;
                } else {
                    strcpy(h_margin_status, "MARGIN_OK");
                }
            } else {
                h_margin_required = 0.0;
                h_margin_shortfall = 0.0;
                strcpy(h_margin_status, "DELIVERY");
            }
        }
    }

    EXEC SQL CLOSE portfolio_cursor;
    EXEC SQL COMMIT;

phase3_report:

    /* ── Phase 3: Chain to BATCH_EQUITY_REPORT via tpforward ──
     * In real Tuxedo, tpforward transfers the request to the next service.
     * The current service terminates and REPORT handles the response.
     */
    userlog("BATCH_EQUITY_TRANSFORM: Phase 3 — Forwarding to BATCH_EQUITY_REPORT");

    EXEC SQL INSERT INTO batch_log (service_name, status, rows_processed)
        VALUES ('BATCH_EQUITY_TRANSFORM', 'SUCCESS', :h_total_processed);

    snprintf(h_status_msg, sizeof(h_status_msg),
             "OK|processed=%d|metrics=%d|portfolios=%d|margin_calls=%d|skipped=%d",
             h_total_processed, h_metrics_computed, h_portfolio_updated,
             h_margin_calls, h_skipped_low_words);

    tpforward("BATCH_EQUITY_REPORT", h_status_msg, strlen(h_status_msg) + 1, 0);
    return;

transform_error:
    EXEC SQL ROLLBACK;
    EXEC SQL INSERT INTO batch_log (service_name, status, rows_processed, error_message)
        VALUES ('BATCH_EQUITY_TRANSFORM', 'FAILED', :h_total_processed, 'SQL error');
    snprintf(h_status_msg, sizeof(h_status_msg),
             "FAIL|processed=%d|sqlcode=%ld", h_total_processed, sqlca.sqlcode);
    tpreturn(TPFAIL, sqlca.sqlcode, h_status_msg, 0, 0);
}
