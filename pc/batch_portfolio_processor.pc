/*
 * batch_portfolio_processor.pc - Tuxedo Portfolio Processing Service
 *
 * Comprehensive portfolio valuation, risk assessment, and margin computation.
 * Processes user portfolios with multiple if/else decision trees that mirror
 * ICICI Securities' actual risk management and portfolio analytics logic.
 *
 * Service: BATCH_PORTFOLIO_PROCESSOR
 * Complexity: MEDIUM (~1000 lines)
 *
 * Real-world analogue: ICICI Securities' Portfolio Analytics System (PAS)
 * that runs nightly to compute client-level:
 *   - Mark-to-market (MTM) valuations
 *   - Risk-adjusted position limits
 *   - Margin requirement calculations
 *   - Concentration risk checks
 *   - P&L attribution (realized + unrealized)
 *   - Segment-wise exposure reports
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>
#include <atmi.h>
#include <userlog.h>

EXEC SQL INCLUDE SQLCA;

/* ─── Risk tier thresholds (from ICICI RMS config) ─────────────────── */

#define HIGH_RISK_BETA         1.5
#define ELEVATED_RISK_BETA     1.2
#define HIGH_DEBT_EQUITY       2.0
#define ELEVATED_DEBT_EQUITY   1.5
#define HIGH_PE                50.0
#define ELEVATED_PE            30.0
#define CONCENTRATION_LIMIT_PCT 20.0
#define MAX_SINGLE_STOCK_PCT   15.0
#define MARGIN_CALL_THRESHOLD  0.25

EXEC SQL BEGIN DECLARE SECTION;
    VARCHAR uid[30];
    VARCHAR pwd[30];

    /* ── Portfolio cursor variables ── */
    int     c_portfolio_id;
    int     c_user_id;
    char    c_ticker[32];
    int     c_quantity;
    double  c_avg_price;
    double  c_invested;
    char    c_holding_since[16];
    char    c_portfolio_type[16];
    char    c_pledge_status[16];

    /* ── User cursor variables ── */
    int     c_u_user_id;
    char    c_u_client_code[16];
    char    c_u_full_name[64];
    char    c_u_segment[16];
    char    c_u_risk_profile[16];
    char    c_u_account_status[16];
    char    c_u_branch_code[32];
    double  c_u_annual_income;
    double  c_u_net_worth;

    /* ── Fundamentals variables ── */
    char    c_f_ticker[32];
    double  c_f_current_price;
    double  c_f_pe_ratio;
    double  c_f_beta;
    double  c_f_debt_equity;
    double  c_f_roe_pct;
    double  c_f_market_cap;
    char    c_f_sector[64];
    double  c_f_high_52w;
    double  c_f_low_52w;
    double  c_f_dividend_yield;
    char    c_f_recommendation[16];

    /* ── Aggregate SELECT INTO variables ── */
    double  h_user_total_value;
    double  h_user_total_invested;
    int     h_user_stock_count;
    double  h_user_max_single_pct;
    char    h_user_max_ticker[32];
    double  h_sector_exposure_total;
    int     h_sector_exposure_count;

    /* ── Derived computation variables ── */
    double  h_current_value;
    double  h_unrealized_pnl;
    double  h_unrealized_pnl_pct;
    double  h_realized_pnl;
    double  h_total_pnl;
    double  h_weight_in_portfolio;
    double  h_risk_score;
    double  h_margin_required;
    double  h_margin_shortfall;
    char    h_risk_tier[32];
    char    h_action_code[32];
    double  h_position_limit;
    double  h_excess_position;

    /* ── Counters and tracking ── */
    int     h_total_users;
    int     h_active_users;
    int     h_dormant_users;
    int     h_closed_users;
    int     h_total_portfolios;
    int     h_delivery_count;
    int     h_margin_count;
    int     h_intraday_count;
    int     h_margin_calls;
    int     h_concentration_breaches;
    int     h_high_risk_users;
    int     h_aggressive_users;
    int     h_moderate_users;
    int     h_conservative_users;
    int     h_commit_count;
    int     h_user_processed;
    int     h_position_count;

    /* ── Output ── */
    char    h_status_msg[4096];
    char    h_report_buffer[16384];
    int     h_report_len;
EXEC SQL END DECLARE SECTION;

static void sql_error(char *msg)
{
    userlog("[FATAL] %s: sqlcode=%ld", msg, sqlca.sqlcode);
    EXEC SQL ROLLBACK;
}

/* ─── tpsvrinit ────────────────────────────────────────────────────── */

int tpsvrinit(int argc, char *argv[])
{
    (void)argc; (void)argv;
    userlog("tpsvrinit: Initializing BATCH_PORTFOLIO_PROCESSOR");

    strcpy((char *)uid.arr, "batch_user");
    uid.len = strlen((char *)uid.arr);
    strcpy((char *)pwd.arr, "batch_pass");
    pwd.len = strlen((char *)pwd.arr);

    EXEC SQL WHENEVER SQLERROR DO sql_error("tpsvrinit CONNECT");
    EXEC SQL CONNECT :uid IDENTIFIED BY :pwd;

    if (sqlca.sqlcode != 0) {
        userlog("tpsvrinit: CONNECT failed");
        return -1;
    }
    userlog("tpsvrinit: BATCH_PORTFOLIO_PROCESSOR ready");
    return 0;
}

/* ─── tpsvrdone ────────────────────────────────────────────────────── */

void tpsvrdone(void)
{
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    EXEC SQL COMMIT WORK RELEASE;
    userlog("tpsvrdone: Users=%d, Portfolios=%d, MarginCalls=%d, Breaches=%d",
            h_user_processed, h_total_portfolios, h_margin_calls,
            h_concentration_breaches);
}

/* ─── determine_risk_tier ───────────────────────────────────────────
 * Classifies a stock position into a risk tier based on fundamentals
 * and price action. This logic is directly from ICICI's RMS.
 */

static const char *determine_risk_tier(double beta, double debt_eq,
                                        double pe, double roe,
                                        const char *recommendation)
{
    if (beta > HIGH_RISK_BETA && debt_eq > HIGH_DEBT_EQUITY)
        return "HIGH_RISK";
    if (beta > HIGH_RISK_BETA && pe > HIGH_PE)
        return "HIGH_RISK";
    if (debt_eq > HIGH_DEBT_EQUITY && pe > HIGH_PE)
        return "HIGH_RISK";
    if (strcmp(recommendation, "sell") == 0)
        return "HIGH_RISK";
    if (beta > ELEVATED_RISK_BETA || debt_eq > ELEVATED_DEBT_EQUITY)
        return "ELEVATED_RISK";
    if (pe > ELEVATED_PE && beta > 1.0)
        return "ELEVATED_RISK";
    if (roe < 5.0 && debt_eq > 1.0)
        return "ELEVATED_RISK";
    if (beta > 0.5 && beta <= ELEVATED_RISK_BETA
        && debt_eq < ELEVATED_DEBT_EQUITY && roe > 10.0)
        return "MODERATE_RISK";
    if (pe < 20.0 && debt_eq < 0.5 && roe > 15.0)
        return "LOW_RISK";
    return "STANDARD_RISK";
}

/* ─── calc_margin_percentage ────────────────────────────────────────
 * Margin % based on risk tier, portfolio type, and user risk profile.
 * These come from ICICI's margin schedule that gets updated by the
 * risk management team based on market conditions.
 */

static double calc_margin_percentage(const char *risk_tier,
                                      const char *portfolio_type,
                                      const char *user_risk_profile)
{
    double base_margin;

    if (strcmp(risk_tier, "HIGH_RISK") == 0) {
        base_margin = 50.0;
    } else if (strcmp(risk_tier, "ELEVATED_RISK") == 0) {
        base_margin = 35.0;
    } else if (strcmp(risk_tier, "MODERATE_RISK") == 0) {
        base_margin = 25.0;
    } else if (strcmp(risk_tier, "LOW_RISK") == 0) {
        base_margin = 15.0;
    } else {
        base_margin = 25.0;
    }

    /* Portfolio type adjustments */
    if (strcmp(portfolio_type, "INTRADAY") == 0) {
        base_margin *= 0.5;
    } else if (strcmp(portfolio_type, "MARGIN") == 0) {
        base_margin *= 0.8;
    }

    /* User risk profile adjustment */
    if (strcmp(user_risk_profile, "AGGRESSIVE") == 0) {
        base_margin *= 1.2;
    } else if (strcmp(user_risk_profile, "CONSERVATIVE") == 0) {
        base_margin *= 0.9;
    }

    return base_margin;
}

/* ─── determine_action_code ─────────────────────────────────────────
 * What action should the system take for this position?
 * ICICI's RMS has 20+ action codes for different scenarios.
 */

static const char *determine_action_code(double unrealized_pnl_pct,
                                          double margin_shortfall,
                                          const char *risk_tier,
                                          double weight_in_portfolio)
{
    if (margin_shortfall > 0 && strcmp(risk_tier, "HIGH_RISK") == 0)
        return "FORCE_SELL";
    if (margin_shortfall > 0)
        return "MARGIN_CALL";
    if (unrealized_pnl_pct < -20.0)
        return "STOP_LOSS_ALERT";
    if (unrealized_pnl_pct < -10.0 && strcmp(risk_tier, "HIGH_RISK") == 0)
        return "REVIEW_REQUIRED";
    if (weight_in_portfolio > CONCENTRATION_LIMIT_PCT)
        return "CONCENTRATION_WARNING";
    if (unrealized_pnl_pct > 50.0)
        return "BOOK_PROFIT_SUGGEST";
    if (unrealized_pnl_pct > 20.0)
        return "TRAILING_STOP";
    if (strcmp(risk_tier, "LOW_RISK") == 0 && unrealized_pnl_pct > 0)
        return "HOLD";
    if (strcmp(risk_tier, "LOW_RISK") == 0)
        return "ACCUMULATE";
    return "MONITOR";
}

/* ─── BATCH_PORTFOLIO_PROCESSOR Service ───────────────────────────── */

void BATCH_PORTFOLIO_PROCESSOR(TPSVCINFO *rqst)
{
    (void)rqst;
    userlog("BATCH_PORTFOLIO_PROCESSOR: Starting portfolio analysis");

    EXEC SQL WHENEVER SQLERROR GOTO portfolio_error;

    /* ── Initialize counters ── */
    h_total_users = 0; h_active_users = 0; h_dormant_users = 0;
    h_closed_users = 0; h_total_portfolios = 0;
    h_delivery_count = 0; h_margin_count = 0; h_intraday_count = 0;
    h_margin_calls = 0; h_concentration_breaches = 0;
    h_high_risk_users = 0; h_aggressive_users = 0;
    h_moderate_users = 0; h_conservative_users = 0;
    h_commit_count = 0; h_user_processed = 0; h_position_count = 0;
    h_report_len = 0;
    memset(h_report_buffer, 0, sizeof(h_report_buffer));

    /* ── Phase 1: User-level processing ──
     * Walk through every user, compute total portfolio value,
     * check concentration limits, classify risk.
     */

    EXEC SQL DECLARE user_cursor CURSOR FOR
        SELECT user_id, client_code, full_name, segment, risk_profile,
               account_status, branch_code, annual_income, net_worth
        FROM users
        ORDER BY user_id;

    EXEC SQL OPEN user_cursor;

    if (sqlca.sqlcode != 0) {
        userlog("BATCH_PORTFOLIO_PROCESSOR: User cursor open failed");
        tpreturn(TPFAIL, sqlca.sqlcode, "FAIL|user_cursor", 0, 0);
        return;
    }

    while (1) {
        EXEC SQL FETCH user_cursor INTO
            :c_u_user_id, :c_u_client_code, :c_u_full_name, :c_u_segment,
            :c_u_risk_profile, :c_u_account_status, :c_u_branch_code,
            :c_u_annual_income, :c_u_net_worth;

        if (sqlca.sqlcode == 100) break;
        if (sqlca.sqlcode != 0) goto portfolio_error;

        h_total_users++;

        /* Classify user by account status */
        if (strcmp(c_u_account_status, "ACTIVE") == 0) {
            h_active_users++;
        } else if (strcmp(c_u_account_status, "DORMANT") == 0) {
            h_dormant_users++;
            /* Dormant users: skip portfolio processing */
            continue;
        } else {
            h_closed_users++;
            continue;
        }

        /* Classify by risk profile */
        if (strcmp(c_u_risk_profile, "AGGRESSIVE") == 0) {
            h_aggressive_users++;
        } else if (strcmp(c_u_risk_profile, "MODERATE") == 0) {
            h_moderate_users++;
        } else {
            h_conservative_users++;
        }

        /* ── Check if user is high-risk based on income/net worth ──
         * ICICI has specific thresholds for classifying users */
        if (c_u_annual_income > 0 && c_u_net_worth > 0) {
            double leverage = (c_u_net_worth - c_u_annual_income) / c_u_net_worth;
            if (leverage > 0.7) {
                h_high_risk_users++;
            }
        }

        h_user_processed++;

        /* Commit per user */
        h_commit_count++;
        if (h_commit_count >= 50) {
            EXEC SQL COMMIT;
            h_commit_count = 0;
        }
    }

    EXEC SQL CLOSE user_cursor;

    /* ── Phase 2: Position-level processing ──
     * Walk through every portfolio holding (position), compute
     * MTM, P&L, risk metrics, margin requirements.
     *
     * This is the core logic: each position goes through multiple
     * if/else decision trees for risk classification, margin
     * computation, and action recommendation.
     */

    userlog("BATCH_PORTFOLIO_PROCESSOR: Phase 2 — Position processing");

    EXEC SQL DECLARE position_cursor CURSOR FOR
        SELECT pf.portfolio_id, pf.user_id, pf.ticker, pf.quantity,
               pf.avg_buy_price, pf.invested_amount, pf.holding_since,
               pf.portfolio_type, pf.pledge_status
        FROM user_portfolios pf
        JOIN users u ON pf.user_id = u.user_id
        WHERE u.account_status = 'ACTIVE'
        ORDER BY pf.user_id, pf.ticker;

    EXEC SQL OPEN position_cursor;

    if (sqlca.sqlcode != 0) {
        userlog("BATCH_PORTFOLIO_PROCESSOR: Position cursor open failed");
        goto portfolio_summary;
    }

    /* Track per-user aggregation */
    {
        int    current_user = -1;
        double user_total_val = 0.0;
        double user_total_inv = 0.0;
        int    user_stocks = 0;
        double user_max_pct = 0.0;
        char   user_max_ticker[32] = "";

        while (1) {
            EXEC SQL FETCH position_cursor INTO
                :c_portfolio_id, :c_user_id, :c_ticker, :c_quantity,
                :c_avg_price, :c_invested, :c_holding_since,
                :c_portfolio_type, :c_pledge_status;

            if (sqlca.sqlcode == 100) {
                /* End of cursor — finalize last user */
                if (current_user >= 0 && user_stocks > 0) {
                    /* Concentration check for last user */
                    if (user_max_pct > CONCENTRATION_LIMIT_PCT) {
                        h_concentration_breaches++;
                    }
                }
                break;
            }
            if (sqlca.sqlcode != 0) goto portfolio_error;

            h_position_count++;

            /* ── Portfolio type counter ── */
            if (strcmp(c_portfolio_type, "DELIVERY") == 0) {
                h_delivery_count++;
            } else if (strcmp(c_portfolio_type, "MARGIN") == 0) {
                h_margin_count++;
            } else if (strcmp(c_portfolio_type, "INTRADAY") == 0) {
                h_intraday_count++;
            }

            /* ── Check if we moved to a new user ── */
            if (c_user_id != current_user) {
                /* Finalize previous user's concentration check */
                if (current_user >= 0 && user_stocks > 0) {
                    if (user_max_pct > CONCENTRATION_LIMIT_PCT) {
                        h_concentration_breaches++;
                    }
                }

                /* Reset for new user */
                current_user = c_user_id;
                user_total_val = 0.0;
                user_total_inv = 0.0;
                user_stocks = 0;
                user_max_pct = 0.0;
                user_max_ticker[0] = '\0';
            }

            /* ── Fetch fundamentals for this stock ── */
            EXEC SQL SELECT current_price, pe_ratio, beta, debt_to_equity,
                        roe_pct, market_cap_crore, sector, high_52w, low_52w,
                        dividend_yield_pct, COALESCE(recommendation, 'hold')
                INTO :c_f_current_price, :c_f_pe_ratio, :c_f_beta,
                     :c_f_debt_equity, :c_f_roe_pct, :c_f_market_cap,
                     :c_f_sector, :c_f_high_52w, :c_f_low_52w,
                     :c_f_dividend_yield, :c_f_recommendation
                FROM stock_fundamentals
                WHERE ticker = :c_ticker;

            /* ── Compute MTM values ── */
            if (c_f_current_price > 0.0) {
                h_current_value = (double)c_quantity * c_f_current_price;
                h_unrealized_pnl = h_current_value - c_invested;
                if (c_invested > 0.0) {
                    h_unrealized_pnl_pct = (h_unrealized_pnl / c_invested) * 100.0;
                } else {
                    h_unrealized_pnl_pct = 0.0;
                }
            } else {
                h_current_value = c_invested;
                h_unrealized_pnl = 0.0;
                h_unrealized_pnl_pct = 0.0;
            }

            /* ── Aggregate user portfolio ── */
            user_total_val += h_current_value;
            user_total_inv += c_invested;
            user_stocks++;

            /* Update running totals for this user */
            {
                /* ── Fetch user profile for margin calc ── */
                char user_rp[16];
                EXEC SQL SELECT risk_profile INTO :user_rp
                    FROM users WHERE user_id = :c_user_id;

                /* ── Risk tier determination ──
                 * Full if/else tree based on multiple fundamental factors */
                {
                    const char *risk_tier = determine_risk_tier(
                        c_f_beta, c_f_debt_equity, c_f_pe_ratio,
                        c_f_roe_pct, c_f_recommendation);

                    /* Margin calculation */
                    double margin_pct = calc_margin_percentage(
                        risk_tier, c_portfolio_type, user_rp);

                    h_margin_required = h_current_value * (margin_pct / 100.0);

                    /* Margin shortfall for non-delivery positions */
                    if (strcmp(c_portfolio_type, "DELIVERY") != 0
                        && c_invested > 0.0) {
                        double equity = c_invested;
                        h_margin_shortfall = h_margin_required - equity;
                        if (h_margin_shortfall > 0) {
                            h_margin_calls++;
                        }
                    } else {
                        h_margin_shortfall = 0.0;
                    }

                    /* ── Position limit check ──
                     * Aggressive users: max 25% in one stock
                     * Moderate: 20%
                     * Conservative: 15% */
                    if (strcmp(user_rp, "AGGRESSIVE") == 0) {
                        h_position_limit = 25.0;
                    } else if (strcmp(user_rp, "MODERATE") == 0) {
                        h_position_limit = 20.0;
                    } else {
                        h_position_limit = 15.0;
                    }

                    /* ── Action code ── */
                    {
                        double weight = 0.0;
                        if (user_total_val > 0.0) {
                            weight = (h_current_value / user_total_val) * 100.0;
                        }
                        const char *action = determine_action_code(
                            h_unrealized_pnl_pct, h_margin_shortfall,
                            risk_tier, weight);

                        /* ── Excess position check ──
                         * Different limits for different risk tiers */
                        if (strcmp(risk_tier, "HIGH_RISK") == 0) {
                            h_position_limit *= 0.5;  /* 50% reduction */
                        } else if (strcmp(risk_tier, "ELEVATED_RISK") == 0) {
                            h_position_limit *= 0.7;  /* 30% reduction */
                        }

                        if (weight > h_position_limit) {
                            h_excess_position = (weight - h_position_limit)
                                * user_total_val / 100.0;
                        } else {
                            h_excess_position = 0.0;
                        }

                        /* Update concentration tracking */
                        if (weight > user_max_pct) {
                            user_max_pct = weight;
                            strncpy(user_max_ticker, c_ticker, 31);
                        }
                    }
                }
            }

            h_total_portfolios++;

            /* Commit every 100 positions */
            h_commit_count++;
            if (h_commit_count >= 100) {
                EXEC SQL COMMIT;
                h_commit_count = 0;
            }
        }
    }

    EXEC SQL CLOSE position_cursor;
    EXEC SQL COMMIT;

portfolio_summary:
    /* ── Phase 3: Summary Report ── */
    h_report_len += snprintf(h_report_buffer + h_report_len,
        sizeof(h_report_buffer) - h_report_len,
        "\n"
        "╔══════════════════════════════════════════════════════════════╗\n"
        "║    ICICI SECURITIES — PORTFOLIO ANALYTICS REPORT          ║\n"
        "╚══════════════════════════════════════════════════════════════╝\n"
        "\n"
        "┌─── USER SUMMARY ───────────────────────────────────────────┐\n"
        "│ Total Users              : %6d                            │\n"
        "│ Active Users             : %6d                            │\n"
        "│ Dormant Users            : %6d                            │\n"
        "│ Closed Accounts          : %6d                            │\n"
        "│                                                           │\n"
        "│ By Risk Profile:                                          │\n"
        "│   Aggressive             : %6d                            │\n"
        "│   Moderate               : %6d                            │\n"
        "│   Conservative           : %6d                            │\n"
        "│   High Risk (leveraged)  : %6d                            │\n"
        "└───────────────────────────────────────────────────────────┘\n"
        "\n"
        "┌─── POSITION SUMMARY ───────────────────────────────────────┐\n"
        "│ Total Positions          : %6d                            │\n"
        "│   DELIVERY               : %6d                            │\n"
        "│   MARGIN                 : %6d                            │\n"
        "│   INTRADAY               : %6d                            │\n"
        "│                                                           │\n"
        "│ Margin Calls Triggered   : %6d                            │\n"
        "│ Concentration Breaches   : %6d                            │\n"
        "└───────────────────────────────────────────────────────────┘\n"
        "\n",
        h_total_users, h_active_users, h_dormant_users, h_closed_users,
        h_aggressive_users, h_moderate_users, h_conservative_users,
        h_high_risk_users,
        h_position_count,
        h_delivery_count, h_margin_count, h_intraday_count,
        h_margin_calls, h_concentration_breaches);

    EXEC SQL COMMIT;

    EXEC SQL INSERT INTO batch_log (service_name, status, rows_processed)
        VALUES ('BATCH_PORTFOLIO_PROCESSOR', 'SUCCESS', :h_position_count);

    userlog("BATCH_PORTFOLIO_PROCESSOR: Complete. Users=%d, Positions=%d",
            h_user_processed, h_position_count);

    tpreturn(TPSUCCESS, 0, h_report_buffer, h_report_len + 1, 0);
    return;

portfolio_error:
    EXEC SQL ROLLBACK;
    EXEC SQL INSERT INTO batch_log (service_name, status, rows_processed, error_message)
        VALUES ('BATCH_PORTFOLIO_PROCESSOR', 'FAILED', :h_position_count, 'SQL error');
    snprintf(h_status_msg, sizeof(h_status_msg),
             "FAIL|sqlcode=%ld", sqlca.sqlcode);
    tpreturn(TPFAIL, sqlca.sqlcode, h_status_msg, 0, 0);
}
