EXEC SQL END DECLARE SECTION;

static void sql_error(char *msg)
{
    userlog("[FATAL] %s: sqlcode=%ld", msg, sqlca.sqlcode);
    EXEC SQL ROLLBACK;
}

/* ─── tpsvrinit ────────────────────────────────────────────────────── */

int tpsvrinit(int argc, char *argv[])
{
    (void)argc; (void)argv;
    userlog("tpsvrinit: Initializing BATCH_MARKET_ANALYTICS");

    strcpy((char *)uid.arr, "batch_user");
    uid.len = strlen((char *)uid.arr);
    strcpy((char *)pwd.arr, "batch_pass");
    pwd.len = strlen((char *)pwd.arr);

    EXEC SQL WHENEVER SQLERROR DO sql_error("tpsvrinit CONNECT");
    EXEC SQL CONNECT :uid IDENTIFIED BY :pwd;

    if (sqlca.sqlcode != 0) {
        userlog("tpsvrinit: CONNECT failed");
        return -1;
    }
    userlog("tpsvrinit: BATCH_MARKET_ANALYTICS ready");
    return 0;
}

/* ─── tpsvrdone ────────────────────────────────────────────────────── */

void tpsvrdone(void)
{
    EXEC SQL WHENEVER SQLERROR CONTINUE;
    EXEC SQL COMMIT WORK RELEASE;
    userlog("tpsvrdone: Market analytics complete. "
            "Stocks=%d, Sectors=%d, Peers=%d groups",
            h_phase2_count, h_phase3_count, h_phase4_count);
}

/* ═══════════════════════════════════════════════════════════════════════
 * SCORING FUNCTIONS
 * Each function implements a specific factor model used by ICICI Research.
 * ═══════════════════════════════════════════════════════════════════════ */

/* ─── Compute Value Score (0-100) ───────────────────────────────────
 * Combines P/E, P/B, P/S, PEG, and Dividend Yield.
 * Lower P/E, P/B, P/S = better value. Higher Div Yield = better value.
 */
static double compute_value_score(double pe, double pb, double ps,
                                   double peg, double div_yield)
{
    double score = 50.0;  /* neutral start */

    /* P/E ratio: lower is better for value */
    if (pe <= 0.0) {
        score += 0.0;  /* negative earnings — can't score */
    } else if (pe < 10.0) {
        score += 20.0;
    } else if (pe < 15.0) {
        score += 15.0;
    } else if (pe < 20.0) {
        score += 10.0;
    } else if (pe < 25.0) {
        score += 5.0;
    } else if (pe < 30.0) {
        score += 0.0;
    } else if (pe < 50.0) {
        score += -10.0;
    } else {
        score += -20.0;
    }

    /* P/B ratio */
    if (pb <= 0.0) {
        score += 0.0;
    } else if (pb < 1.0) {
        score += 15.0;
    } else if (pb < 1.5) {
        score += 10.0;
    } else if (pb < 3.0) {
        score += 5.0;
    } else if (pb < 5.0) {
        score += -5.0;
    } else {
        score += -15.0;
    }

    /* P/S ratio */
    if (ps <= 0.0) {
        score += 0.0;
    } else if (ps < 1.0) {
        score += 10.0;
    } else if (ps < 2.0) {
        score += 5.0;
    } else if (ps < 5.0) {
        score += 0.0;
    } else {
        score += -10.0;
    }

    /* PEG ratio */
    if (peg > 0.0 && peg < 1.0) {
        score += 10.0;
    } else if (peg >= 1.0 && peg < 2.0) {
        score += 5.0;
    } else if (peg >= 3.0) {
        score += -10.0;
    }

    /* Dividend yield */
    if (div_yield > 3.0) {
        score += 10.0;
    } else if (div_yield > 2.0) {
        score += 5.0;
    } else if (div_yield > 1.0) {
        score += 2.0;
    }

    if (score > 100.0) return 100.0;
    if (score < 0.0) return 0.0;
    return score;
}

/* ─── Compute Growth Score (0-100) ──────────────────────────────────
 * Revenue growth, earnings growth, quarterly momentum, forward estimates.
 */
static double compute_growth_score(double rev_growth, double earn_growth,
                                    double earn_q_growth, double fwd_pe,
                                    double pe, double peg)
{
    double score = 50.0;

    /* Revenue growth */
    if (rev_growth > 30.0) {
        score += 20.0;
    } else if (rev_growth > 20.0) {
        score += 15.0;
    } else if (rev_growth > 10.0) {
        score += 10.0;
    } else if (rev_growth > 5.0) {
        score += 5.0;
    } else if (rev_growth > 0.0) {
        score += 0.0;
    } else if (rev_growth > -10.0) {
        score += -10.0;
    } else {
        score += -20.0;
    }

    /* Earnings growth */
    if (earn_growth > 25.0) {
        score += 20.0;
    } else if (earn_growth > 15.0) {
        score += 15.0;
    } else if (earn_growth > 10.0) {
        score += 10.0;
    } else if (earn_growth > 0.0) {
        score += 0.0;
    } else if (earn_growth > -20.0) {
        score += -10.0;
    } else {
        score += -20.0;
    }

    /* Quarterly growth acceleration */
    if (earn_q_growth > earn_growth + 5.0) {
        score += 10.0;  /* accelerating */
    } else if (earn_q_growth > earn_growth) {
        score += 5.0;
    } else if (earn_q_growth < earn_growth - 10.0) {
        score += -10.0;  /* decelerating */
    }

    /* Forward P/E vs trailing (lower = growth expected) */
    if (fwd_pe > 0 && pe > 0 && fwd_pe < pe * 0.8) {
        score += 10.0;
    }

    /* PEG < 1 suggests undervalued growth */
    if (peg > 0 && peg < 1.0) {
        score += 10.0;
    }

    if (score > 100.0) return 100.0;
    if (score < 0.0) return 0.0;
    return score;
}

/* ─── Compute Quality Score (0-100) ─────────────────────────────────
 * ROE, ROCE-like (ROA), margins, debt levels, cash flows.
 */
static double compute_quality_score(double roe, double roa,
                                     double op_margin, double gross_margin,
                                     double debt_eq, double current_ratio,
                                     double free_cf, double op_cf)
{
    double score = 50.0;

    /* ROE */
    if (roe > 25.0) {
        score += 15.0;
    } else if (roe > 20.0) {
        score += 12.0;
    } else if (roe > 15.0) {
        score += 8.0;
    } else if (roe > 10.0) {
        score += 4.0;
    } else if (roe > 5.0) {
        score += 0.0;
    } else if (roe > 0.0) {
        score += -8.0;
    } else {
        score += -15.0;
    }

    /* ROA */
    if (roa > 10.0) {
        score += 10.0;
    } else if (roa > 5.0) {
        score += 5.0;
    } else if (roa < 0.0) {
        score += -10.0;
    }

    /* Operating margin */
    if (op_margin > 25.0) {
        score += 10.0;
    } else if (op_margin > 15.0) {
        score += 5.0;
    } else if (op_margin < 5.0) {
        score += -10.0;
    }

    /* Gross margin */
    if (gross_margin > 50.0) {
        score += 5.0;
    } else if (gross_margin < 20.0) {
        score += -5.0;
    }

    /* Debt to equity */
    if (debt_eq < 0.3) {
        score += 10.0;
    } else if (debt_eq < 0.5) {
        score += 8.0;
    } else if (debt_eq < 1.0) {
        score += 5.0;
    } else if (debt_eq < 1.5) {
        score += 0.0;
    } else if (debt_eq < 2.0) {
        score += -5.0;
    } else {
        score += -15.0;
    }

    /* Current ratio */
    if (current_ratio > 2.0) {
        score += 5.0;
    } else if (current_ratio < 1.0) {
        score += -10.0;
    }

    /* Free cash flow positive */
    if (free_cf > 0) {
        score += 5.0;
    } else {
        score += -5.0;
    }

    if (score > 100.0) return 100.0;
    if (score < 0.0) return 0.0;
    return score;
}

/* ─── Compute Momentum Score (0-100) ─────────────────────────────────
 * Price momentum over 1, 3, 6 months, SMA crossover, RSI context.
 */
static double compute_momentum_score(double mom_1m, double mom_3m,
                                      double mom_6m, double price_vs_sma50,
                                      double price_vs_sma200, double rsi,
                                      double macd_signal)
{
    double score = 50.0;

    /* 1-month momentum */
    if (mom_1m > 15.0) score += 15.0;
    else if (mom_1m > 10.0) score += 10.0;
    else if (mom_1m > 5.0) score += 5.0;
    else if (mom_1m > 0.0) score += 2.0;
    else if (mom_1m > -5.0) score += -5.0;
    else if (mom_1m > -10.0) score += -10.0;
    else score += -15.0;

    /* 3-month momentum */
    if (mom_3m > 25.0) score += 10.0;
    else if (mom_3m > 15.0) score += 5.0;
    else if (mom_3m < -15.0) score += -10.0;

    /* 6-month momentum */
    if (mom_6m > 30.0) score += 5.0;
    else if (mom_6m < -20.0) score += -5.0;

    /* SMA relationship (golden cross / death cross) */
    if (price_vs_sma50 > 1.0 && price_vs_sma200 > 1.0) {
        score += 10.0;
        if (price_vs_sma50 > price_vs_sma200) {
            score += 5.0;  /* SMA 50 > SMA 200 = bullish */
        }
    } else if (price_vs_sma50 < 1.0 && price_vs_sma200 < 1.0) {
        score += -10.0;
    }

    /* RSI context */
    if (rsi > 70.0) {
        score += -5.0;  /* overbought */
    } else if (rsi < 30.0) {
        score += 5.0;   /* oversold — potential reversal */
    } else if (rsi >= 40.0 && rsi <= 60.0) {
        score += 3.0;   /* neutral zone */
    }

    /* MACD signal */
    if (macd_signal > 0) score += 5.0;

    if (score > 100.0) return 100.0;
    if (score < 0.0) return 0.0;
    return score;
}

/* ─── Compute Low Volatility Score (0-100) ──────────────────────────
 * Lower volatility and beta = higher score (for defensive investors).
 */
static double compute_low_vol_score(double beta, double volatility_30d,
                                     double debt_eq, double div_yield)
{
    double score = 50.0;

    if (beta < 0.5) score += 20.0;
    else if (beta < 0.8) score += 15.0;
    else if (beta < 1.0) score += 10.0;
    else if (beta < 1.2) score += 0.0;
    else if (beta < 1.5) score += -10.0;
    else score += -20.0;

    if (volatility_30d < 1.0) score += 15.0;
    else if (volatility_30d < 2.0) score += 10.0;
    else if (volatility_30d < 3.0) score += 0.0;
    else score += -10.0;

    if (debt_eq < 0.5) score += 10.0;
    if (div_yield > 2.0) score += 5.0;

    if (score > 100.0) return 100.0;
    if (score < 0.0) return 0.0;
    return score;
}

/* ─── Compute Composite Score & Rating ───────────────────────────────
 * Weighted blend of all factor scores.
 * Weights vary by market cap segment (different factors matter more
 * for large caps vs small caps).
 */
static void compute_composite(double value, double growth, double quality,
                               double momentum, double low_vol,
                               double mcap, char *rating, char *outlook)
{
    double composite;
    double w_value, w_growth, w_quality, w_momentum, w_low_vol;

    /* Weight adjustment based on market cap segment */
    if (mcap > LARGE_CAP_CRORE) {
        /* Large cap: quality and low-vol matter most */
        w_value = 0.20;
        w_growth = 0.15;
        w_quality = 0.30;
        w_momentum = 0.15;
        w_low_vol = 0.20;
    } else if (mcap > MID_CAP_CRORE) {
        /* Mid cap: growth and momentum dominate */
        w_value = 0.20;
        w_growth = 0.30;
        w_quality = 0.20;
        w_momentum = 0.20;
        w_low_vol = 0.10;
    } else {
        /* Small cap: growth and momentum are key */
        w_value = 0.15;
        w_growth = 0.35;
        w_quality = 0.15;
        w_momentum = 0.30;
        w_low_vol = 0.05;
    }

    composite = (value * w_value) + (growth * w_growth)
              + (quality * w_quality) + (momentum * w_momentum)
              + (low_vol * w_low_vol);

    /* Rating classification */
    if (composite >= 80.0) {
        strcpy(rating, "STRONG_BUY");
        strcpy(outlook, "Highly Favorable");
    } else if (composite >= 70.0) {
        strcpy(rating, "BUY");
        strcpy(outlook, "Favorable");
    } else if (composite >= 60.0) {
        strcpy(rating, "ACCUMULATE");
        strcpy(outlook, "Moderately Positive");
    } else if (composite >= 50.0) {
        strcpy(rating, "HOLD");
        strcpy(outlook, "Neutral");
    } else if (composite >= 40.0) {
        strcpy(rating, "REDUCE");
        strcpy(outlook, "Cautious");
    } else if (composite >= 30.0) {
        strcpy(rating, "SELL");
        strcpy(outlook, "Negative");
    } else {
        strcpy(rating, "STRONG_SELL");
        strcpy(outlook, "Highly Negative");
    }
}

/* ─── Classify market cap segment ──────────────────────────────────── */

static const char *classify_mcap(double mcap_crore)
{
    if (mcap_crore > LARGE_CAP_CRORE) return "LARGE_CAP";
    if (mcap_crore > MID_CAP_CRORE) return "MID_CAP";
    return "SMALL_CAP";
}

/* ─── Classify recommendation ──────────────────────────────────────── */

static const char *classify_rec(double composite)
{
    if (composite >= 75.0) return "STRONG_BUY";
    if (composite >= 65.0) return "BUY";
    if (composite >= 50.0) return "HOLD";
    if (composite >= 35.0) return "SELL";
    return "STRONG_SELL";
}


/* ═══════════════════════════════════════════════════════════════════════
 * BATCH_MARKET_ANALYTICS Service
 * ═══════════════════════════════════════════════════════════════════════ */

void BATCH_MARKET_ANALYTICS(TPSVCINFO *rqst)
{
    (void)rqst;
    userlog("BATCH_MARKET_ANALYTICS: Starting comprehensive market analysis");

    EXEC SQL WHENEVER SQLERROR GOTO analytics_error;

    /* ── Initialize ── */
    h_phase1_count = 0; h_phase2_count = 0; h_phase3_count = 0;
    h_phase4_count = 0; h_phase5_stocks = 0; h_error_count = 0;
    h_commit_count = 0;
    h_report_len = 0;
    memset(h_report, 0, sizeof(h_report));
    memset(h_prev_sector, 0, sizeof(h_prev_sector));

    /* ── Market breadth init ── */
    h_market_total = 0; h_market_above_sma50 = 0; h_market_above_sma200 = 0;
    h_market_positive_momentum = 0; h_market_rsi_oversold = 0;
    h_market_rsi_overbought = 0; h_market_macd_bullish = 0;
    h_market_large_cap = 0; h_market_mid_cap = 0; h_market_small_cap = 0;
    h_market_total_mcap = 0.0; h_sector_positive_count = 0.0;
    h_sector_sma50_above_count = 0.0; h_sector_stock_count = 0;
    h_sector_total_mcap = 0.0; h_sector_avg_pe = 0.0;
    h_sector_avg_roe = 0.0; h_sector_avg_debt_eq = 0.0;
    h_sector_avg_rev_growth = 0.0; h_sector_avg_momentum = 0.0;
    h_sector_best_composite = 0.0;
    h_best_composite = 0.0;

    /* ══════════════════════════════════════════════════════════════════
     * PHASE 1: Technical Indicator Computation
     * Fetch EOD prices, compute SMA, EMA, RSI, MACD, Bollinger Bands,
     * ATR, and momentum for each stock.
     * ══════════════════════════════════════════════════════════════════ */

    userlog("BATCH_MARKET_ANALYTICS: Phase 1 — Technical Indicators");

    EXEC SQL DECLARE technical_cursor CURSOR FOR
        SELECT ticker, date, close, volume
        FROM eod_prices
        WHERE date >= '2026-01-01'
        ORDER BY ticker, date DESC;

    EXEC SQL OPEN technical_cursor;

    if (sqlca.sqlcode != 0) {
        userlog("Phase 1: Technical cursor open failed. Continuing...");
        /* Non-fatal: proceed with fundamentals only */
        goto phase2_fundamentals;
    }

    {
        char prev_ticker[32] = "";
        int days_seen = 0;

        while (1) {
            EXEC SQL FETCH technical_cursor INTO
                :c_ticker, :c_eod_date, :c_eod_close, :c_eod_volume;

            if (sqlca.sqlcode == 100) break;
            if (sqlca.sqlcode != 0) goto analytics_error;

            /* Track per-ticker technical data */
            if (strcmp(c_ticker, prev_ticker) != 0) {
                /* New ticker — compute metrics for previous */
                if (days_seen >= 50) {
                    /* Enough data for SMA-50 calculation */
                    EXEC SQL SELECT AVG(close) INTO :h_sma_50
                        FROM (SELECT close FROM eod_prices
                              WHERE ticker = :prev_ticker
                              ORDER BY date DESC LIMIT 50);
                }
                if (days_seen >= 200) {
                    EXEC SQL SELECT AVG(close) INTO :h_sma_200
                        FROM (SELECT close FROM eod_prices
                              WHERE ticker = :prev_ticker
                              ORDER BY date DESC LIMIT 200);
                }

                /* Store computed metrics for previous ticker */
                if (days_seen >= 14 && h_sma_50 > 0) {
                    h_price_vs_sma50 = c_eod_close / h_sma_50;
                    h_price_vs_sma200 = (h_sma_200 > 0) ? c_eod_close / h_sma_200 : 1.0;
                }

                strcpy(prev_ticker, c_ticker);
                days_seen = 0;
            }

            days_seen++;
            h_phase1_count++;
        }
    }

    EXEC SQL CLOSE technical_cursor;
    EXEC SQL COMMIT;

    userlog("Phase 1: Complete. %d price points processed", h_phase1_count);

phase2_fundamentals:
    /* ══════════════════════════════════════════════════════════════════
     * PHASE 2: Multi-Factor Fundamental Scoring
     * Walk through ALL 48 fundamental columns for each stock.
     * Compute Value, Growth, Quality, Momentum, and Low-Vol scores.
     * Then blend into a composite score with a rating.
     * ══════════════════════════════════════════════════════════════════ */

    userlog("BATCH_MARKET_ANALYTICS: Phase 2 — Fundamental Factor Scoring");

    EXEC SQL DECLARE fundamental_cursor CURSOR FOR
        SELECT ticker, company_name, sector, industry, exchange,
               current_price, market_cap_crore,
               pe_ratio, forward_pe, pb_ratio, peg_ratio, price_to_sales,
               roe_pct, roa_pct,
               profit_margins_pct, operating_margins_pct,
               gross_margins_pct, ebitda_margins_pct,
               eps_ttm, eps_forward, book_value_per_share, revenue_per_share,
               revenue_growth_pct, earnings_growth_pct,
               earnings_quarterly_growth_pct,
               debt_to_equity, current_ratio, quick_ratio, payout_ratio,
               dividend_yield_pct, five_year_avg_dividend_yield_pct,
               high_52w, low_52w, beta,
               target_mean_price, target_high_price, target_low_price,
               COALESCE(recommendation, 'hold'), number_of_analysts,
               held_pct_insiders, held_pct_institutions,
               free_cashflow, operating_cashflow, total_cash_per_share,
               total_debt, total_revenue, ebitda
        FROM stock_fundamentals
        WHERE current_price > 0
        ORDER BY sector, market_cap_crore DESC;

    EXEC SQL OPEN fundamental_cursor;

    if (sqlca.sqlcode != 0) {
        userlog("Phase 2: Fundamental cursor open failed");
        tpreturn(TPFAIL, sqlca.sqlcode, "FAIL|fundamental_cursor", 0, 0);
        return;
    }

    /* ── Sector state tracking ── */
    h_prev_sector[0] = '\0';
    h_sector_stock_count = 0;
    h_sector_total_mcap = 0.0;

    while (1) {
        /* ── Fetch ALL 48 columns ── */
        EXEC SQL FETCH fundamental_cursor INTO
            :c_ticker, :c_company, :c_sector, :c_industry, :c_exchange,
            :c_price, :c_mcap,
            :c_pe, :c_fwd_pe, :c_pb, :c_peg, :c_ps,
            :c_roe, :c_roa,
            :c_profit_margin, :c_op_margin,
            :c_gross_margin, :c_ebitda_margin,
            :c_eps, :c_eps_fwd, :c_book_val, :c_rev_per_share,
            :c_rev_growth, :c_earn_growth,
            :c_earn_q_growth,
            :c_debt_eq, :c_current_ratio, :c_quick_ratio, :c_payout,
            :c_div_yield, :c_div_5y,
            :c_high_52w, :c_low_52w, :c_beta,
            :c_target_mean, :c_target_high, :c_target_low,
            :c_recommendation, :c_analysts,
            :c_insider_pct, :c_inst_pct,
            :c_free_cf, :c_op_cf, :c_cash_per_share,
            :c_total_debt, :c_total_rev, :c_ebitda;

        if (sqlca.sqlcode == 100) break;
        if (sqlca.sqlcode != 0) {
            h_error_count++;
            if (h_error_count > 10) goto analytics_error;
            continue;
        }

        h_phase2_count++;
        h_market_total++;

        /* ── Market cap classification ── */
        {
            const char *mcap_class = classify_mcap(c_mcap);
            if (strcmp(mcap_class, "LARGE_CAP") == 0) h_market_large_cap++;
            else if (strcmp(mcap_class, "MID_CAP") == 0) h_market_mid_cap++;
            else h_market_small_cap++;
        }
        h_market_total_mcap += c_mcap;

        /* ── Sector transition check ──
         * When sector changes, finalize the previous sector's aggregates
         * and compute sector-level analytics. */
        if (strlen(h_prev_sector) > 0
            && strcmp(c_sector, h_prev_sector) != 0) {

            if (h_sector_stock_count > 0) {
                h_sector_avg_pe /= h_sector_stock_count;
                h_sector_avg_roe /= h_sector_stock_count;
                h_sector_avg_debt_eq /= h_sector_stock_count;
                h_sector_avg_rev_growth /= h_sector_stock_count;

                /* Upsert sector analytics */
                EXEC SQL INSERT OR REPLACE INTO sector_analytics
                    (sector, as_of_date, total_mcap, avg_pe, avg_roe,
                     avg_debt_equity, stock_count)
                    VALUES (:h_prev_sector, DATE('now'),
                            :h_sector_total_mcap, :h_sector_avg_pe,
                            :h_sector_avg_roe, :h_sector_avg_debt_eq,
                            :h_sector_stock_count);

                h_phase3_count++;
            }

            /* Reset for new sector */
            h_sector_total_mcap = 0.0;
            h_sector_avg_pe = 0.0;
            h_sector_avg_roe = 0.0;
            h_sector_avg_debt_eq = 0.0;
            h_sector_avg_rev_growth = 0.0;
            h_sector_stock_count = 0;
            h_sector_best_composite = 0.0;
        }
        strcpy(h_prev_sector, c_sector);

        /* Accumulate sector totals */
        h_sector_total_mcap += c_mcap;
        h_sector_avg_pe += c_pe;
        h_sector_avg_roe += c_roe;
        h_sector_avg_debt_eq += c_debt_eq;
        h_sector_avg_rev_growth += c_rev_growth;
        h_sector_stock_count++;

        /* ── Calculate price vs 52-week range ── */
        if (c_high_52w > 0 && c_low_52w > 0) {
            double range = c_high_52w - c_low_52w;
            h_price_vs_52w_low = (c_price - c_low_52w) / range * 100.0;
            h_price_vs_52w_high = (c_high_52w - c_price) / range * 100.0;
        }

        /* ── Fetch technical indicators for this stock ── */
        EXEC SQL SELECT sma_50, sma_200, daily_return, volatility_30d
            INTO :h_sma_50, :h_sma_200, :h_momentum_1m, :h_volatility_30d
            FROM equity_derived_metrics
            WHERE ticker = :c_ticker
            ORDER BY date DESC LIMIT 1;

        /* ── Compute factor scores (all 5 factors) ── */
        h_value_score = compute_value_score(c_pe, c_pb, c_ps, c_peg, c_div_yield);
        h_growth_score = compute_growth_score(c_rev_growth, c_earn_growth,
                                               c_earn_q_growth, c_fwd_pe,
                                               c_pe, c_peg);
        h_quality_score = compute_quality_score(c_roe, c_roa, c_op_margin,
                                                 c_gross_margin, c_debt_eq,
                                                 c_current_ratio, c_free_cf,
                                                 c_op_cf);
        h_momentum_score = compute_momentum_score(h_momentum_1m, 0.0, 0.0,
                                                   0.0, 0.0, 50.0, 0.0);
        h_low_vol_score = compute_low_vol_score(c_beta, h_volatility_30d,
                                                 c_debt_eq, c_div_yield);

        /* ── Composite score and rating ── */
        compute_composite(h_value_score, h_growth_score, h_quality_score,
                          h_momentum_score, h_low_vol_score, c_mcap,
                          h_rating, h_outlook);

        /* ── Market breadth accumulation ── */
        if (h_momentum_1m > 0) h_market_positive_momentum++;
        if (h_sma_50 > 0 && c_price > h_sma_50) h_market_above_sma50++;
        if (h_sma_200 > 0 && c_price > h_sma_200) h_market_above_sma200++;
        if (h_volatility_30d < 2.0) h_market_macd_bullish++;

        /* Track best composite score */
        if (h_value_score + h_growth_score + h_quality_score
            + h_momentum_score + h_low_vol_score > h_best_composite) {
            h_best_composite = h_value_score + h_growth_score + h_quality_score
                             + h_momentum_score + h_low_vol_score;
            strncpy(h_best_ticker, c_ticker, 31);
        }

        /* ── Phase 4: Peer Group Comparison ──
         * For each sector, track the top 10 by market cap for peer analysis.
         * In production, peers are selected based on industry, size, and
         * business model similarity. */
        if (h_sector_stock_count <= 10) {
            int idx = h_sector_stock_count - 1;
            if (idx >= 0 && idx < 10) {
                strncpy(h_peer_tickers[idx], c_ticker, 31);
                h_peer_mcaps[idx] = c_mcap;
                h_peer_pes[idx] = c_pe;
                h_peer_roes[idx] = c_roe;
                h_peer_rev_growths[idx] = c_rev_growth;
            }
        }
        h_phase4_count++;

        /* Commit every 50 stocks */
        h_commit_count++;
        if (h_commit_count >= 50) {
            EXEC SQL COMMIT;
            h_commit_count = 0;
        }
    }

    /* Finalize last sector */
    if (h_sector_stock_count > 0 && strlen(h_prev_sector) > 0) {
        h_sector_avg_pe /= h_sector_stock_count;
        h_sector_avg_roe /= h_sector_stock_count;
        h_sector_avg_debt_eq /= h_sector_stock_count;
        h_sector_avg_rev_growth /= h_sector_stock_count;

        EXEC SQL INSERT OR REPLACE INTO sector_analytics
            (sector, as_of_date, total_mcap, avg_pe, avg_roe,
             avg_debt_equity, stock_count)
            VALUES (:h_prev_sector, DATE('now'),
                    :h_sector_total_mcap, :h_sector_avg_pe,
                    :h_sector_avg_roe, :h_sector_avg_debt_eq,
                    :h_sector_stock_count);
    }

    EXEC SQL CLOSE fundamental_cursor;
    EXEC SQL COMMIT;

    userlog("Phase 2-4: Complete. %d stocks scored, %d sectors, %d peer groups",
            h_phase2_count, h_phase3_count, h_phase4_count);

    /* ══════════════════════════════════════════════════════════════════
     * PHASE 5: Market Breadth & Sentiment Calculation
     * ══════════════════════════════════════════════════════════════════ */

    EXEC SQL SELECT COUNT(*) INTO :h_total_with_fundamentals
        FROM stock_fundamentals WHERE current_price > 0;

    EXEC SQL SELECT AVG(pe_ratio), AVG(roe_pct)
        INTO :h_avg_market_pe, :h_avg_market_roe
        FROM stock_fundamentals;

    /* Advance-Decline ratio */
    h_market_adv_decline = (h_market_positive_momentum > 0 && h_market_total > 0)
        ? (double)h_market_positive_momentum
          / (double)(h_market_total - h_market_positive_momentum)
        : 1.0;

    /* ── Phase 6: Composite Summary Queries ── */
    {
        /* Top 10 by composite (simulated) */
        EXEC SQL SELECT ticker, market_cap_crore
            INTO :h_best_ticker, :c_mcap
            FROM stock_fundamentals
            ORDER BY market_cap_crore DESC LIMIT 1;
    }

    /* ══════════════════════════════════════════════════════════════════
     * PHASE 7: Analytics Report
     * ══════════════════════════════════════════════════════════════════ */

    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "\n"
        "╔══════════════════════════════════════════════════════════════════╗\n"
        "║  ICICI SECURITIES — COMPREHENSIVE MARKET ANALYTICS            ║\n"
        "║  Multi-Factor Model | Technical + Fundamental + Sentiment     ║\n"
        "╚══════════════════════════════════════════════════════════════════╝\n"
        "\n");

    /* Section A: Market Breadth */
    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "┌─── A. MARKET BREADTH INDICATORS ───────────────────────────┐\n"
        "│ Total Stocks Analyzed      : %6d                          │\n"
        "│   Large Cap (>20K Cr)     : %6d                          │\n"
        "│   Mid Cap (5K-20K Cr)     : %6d                          │\n"
        "│   Small Cap (<5K Cr)      : %6d                          │\n"
        "│ Total Market Cap           : %12.0f Cr                 │\n"
        "│                                                            │\n"
        "│ Above SMA-50               : %6d  (%5.1f%%)               │\n"
        "│ Above SMA-200              : %6d  (%5.1f%%)               │\n"
        "│ Positive 1-Mo Momentum     : %6d  (%5.1f%%)               │\n"
        "│ Advance/Decline Ratio      : %8.2f                        │\n"
        "│ Market P/E (avg)           : %8.2f                        │\n"
        "│ Market ROE (avg)           : %8.2f%%                       │\n"
        "└────────────────────────────────────────────────────────────┘\n"
        "\n",
        h_phase2_count,
        h_market_large_cap, h_market_mid_cap, h_market_small_cap,
        h_market_total_mcap,
        h_market_above_sma50,
        h_market_total > 0 ? (double)h_market_above_sma50/h_market_total*100 : 0,
        h_market_above_sma200,
        h_market_total > 0 ? (double)h_market_above_sma200/h_market_total*100 : 0,
        h_market_positive_momentum,
        h_market_total > 0 ? (double)h_market_positive_momentum/h_market_total*100 : 0,
        h_market_adv_decline,
        h_avg_market_pe, h_avg_market_roe);

    /* Section B: Sector Rankings */
    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "┌─── B. SECTOR RANKINGS (by market cap) ────────────────────┐\n");

    {
        EXEC SQL DECLARE sector_rank_cursor CURSOR FOR
            SELECT sector, total_mcap, avg_pe, avg_roe, stock_count
            FROM sector_analytics
            ORDER BY total_mcap DESC LIMIT 10;

        EXEC SQL OPEN sector_rank_cursor;

        if (sqlca.sqlcode == 0) {
            while (1) {
                EXEC SQL FETCH sector_rank_cursor INTO
                    :s_sector, :s_mcap, :s_pe, :s_roe, :s_count;

                if (sqlca.sqlcode == 100) break;
                if (sqlca.sqlcode != 0) break;

                h_report_len += snprintf(h_report + h_report_len,
                    sizeof(h_report) - h_report_len,
                    "│ %-20s  %6d stks  PE=%5.1f  ROE=%5.1f%%       │\n",
                    s_sector, s_count, s_pe, s_roe);
            }
        }
        EXEC SQL CLOSE sector_rank_cursor;
    }

    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "└────────────────────────────────────────────────────────────┘\n"
        "\n");

    /* Section C: Factor Model Summary */
    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "┌─── C. MULTI-FACTOR MODEL SUMMARY ─────────────────────────┐\n"
        "│ Factors computed per stock:                               │\n"
        "│   1. Value      (P/E, P/B, P/S, PEG, Div Yield)          │\n"
        "│   2. Growth     (Rev, Earnings, Qtrly, Fwd est.)         │\n"
        "│   3. Quality    (ROE, ROA, Margins, Debt, Cash Flow)     │\n"
        "│   4. Momentum   (1M/3M/6M, SMA cross, RSI, MACD)         │\n"
        "│   5. Low Vol    (Beta, Volatility, Debt, Dividends)      │\n"
        "│                                                            │\n"
        "│ Scoring: 0-100 per factor. Composite = weighted blend.     │\n"
        "│ Ratings: STRONG_BUY > BUY > ACCUMULATE > HOLD >           │\n"
        "│          REDUCE > SELL > STRONG_SELL                       │\n"
        "└────────────────────────────────────────────────────────────┘\n"
        "\n");

    /* Section D: Top Picks */
    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "┌─── D. TOP COMPOSITE SCORE ────────────────────────────────┐\n"
        "│ Best Stock: %-12s  Score: %.0f/500                    │\n"
        "│ Largest by Market Cap: %-12s  %.0f Cr                │\n"
        "└────────────────────────────────────────────────────────────┘\n"
        "\n",
        h_best_ticker, h_best_composite,
        h_best_ticker, c_mcap);

    /* Section E: Processing Summary */
    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "┌─── E. PROCESSING STATISTICS ──────────────────────────────┐\n"
        "│ Phase 1 — Technical Indicators  : %8d rows             │\n"
        "│ Phase 2 — Fundamental Scoring    : %8d stocks           │\n"
        "│ Phase 3 — Sector Aggregation     : %8d sectors          │\n"
        "│ Phase 4 — Peer Groups            : %8d entries          │\n"
        "│ Phase 5 — Market Breadth         : %8d indicators       │\n"
        "│ Errors (skipped)                 : %8d                   │\n"
        "└────────────────────────────────────────────────────────────┘\n"
        "\n",
        h_phase1_count, h_phase2_count, h_phase3_count,
        h_phase4_count, h_phase5_stocks, h_error_count);

    /* Footer */
    h_report_len += snprintf(h_report + h_report_len,
        sizeof(h_report) - h_report_len,
        "╔══════════════════════════════════════════════════════════════════╗\n"
        "║  END OF MARKET ANALYTICS — ICICI SECURITIES RESEARCH          ║\n"
        "╚══════════════════════════════════════════════════════════════════╝\n");

    EXEC SQL COMMIT;

    EXEC SQL INSERT INTO batch_log (service_name, status, rows_processed)
        VALUES ('BATCH_MARKET_ANALYTICS', 'SUCCESS', :h_phase2_count);

    userlog("BATCH_MARKET_ANALYTICS: Complete. Report=%d bytes, "
            "Stocks=%d, Sectors=%d",
            h_report_len, h_phase2_count, h_phase3_count);

    tpreturn(TPSUCCESS, 0, h_report, h_report_len + 1, 0);
    return;

analytics_error:
    EXEC SQL ROLLBACK;
    EXEC SQL INSERT INTO batch_log (service_name, status, rows_processed, error_message)
        VALUES ('BATCH_MARKET_ANALYTICS', 'FAILED', :h_phase2_count, 'SQL error');
    snprintf(h_status_msg, sizeof(h_status_msg),
             "FAIL|phase2=%d|sqlcode=%ld", h_phase2_count, sqlca.sqlcode);
    tpreturn(TPFAIL, sqlca.sqlcode, h_status_msg, 0, 0);
}
